# ─── Supabase ─────────────────────────────────────────────────────────────────
# Server-only. Never expose to the client bundle.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-commit

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Server-only. Never expose to the client bundle.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-never-commit
TELEGRAM_CHAT_ID=your-private-group-chat-id

# ─── Analytics ────────────────────────────────────────────────────────────────
# Public — safe to expose. Prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=0000000000000000

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://miracleivf.uz

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Server-only.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
